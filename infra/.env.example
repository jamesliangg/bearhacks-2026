SNOWFLAKE_ACCOUNT=xxxxx-xx00000
SNOWFLAKE_USER=VIA_DELAY_USER
# PAT/OAuth token auth (preferred)
SNOWFLAKE_TOKEN=change-me

# Optional: Auth0-backed vault fetch (tenant-level)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_SNOWFLAKE_TOKEN_URL=
VAULT_ADMIN_TOKEN=change-me-super-secret

# Password auth fallback (leave empty when using PAT)
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=VIA_DELAY_ROLE
SNOWFLAKE_WAREHOUSE=VIA_DELAY_WH
SNOWFLAKE_DATABASE=VIA_DELAYS
SNOWFLAKE_SCHEMA_RAW=RAW
SNOWFLAKE_SCHEMA_STAGING=STAGING
SNOWFLAKE_SCHEMA_MART=MART

MODEL_DIR=/app/models
ACTIVE_MODEL_FILE=active.joblib

INGESTION_BASE_URL=http://ingestion:8000
TRAINING_BASE_URL=http://training:8000
PREDICTION_BASE_URL=http://prediction:8000

SCRAPE_USER_AGENT=via-delay-oracle/0.1 (+https://example.com)
TRANSITDOCS_BASE=https://asm.transitdocs.com
VIA_LIVE_BASE=https://tsimobile.viarail.ca

USE_SNOWFLAKE=false
LOCAL_SQLITE_PATH=/app/data/via_delays.sqlite

# Ingestion "vault" endpoint (simple local store; protect with admin token)
VAULT_ADMIN_TOKEN=
VAULT_DB_PATH=/tmp/via_vault.sqlite
